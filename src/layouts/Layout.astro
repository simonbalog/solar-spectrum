---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Mellotech | Student Rocket Development", 
  description = "Mellotech is a student rocket development team building reusable aerospace knowledge, OBC boards, and launch vehicles." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
  </head>
  <body>
    <div class="layout-container">
      <slot />
    </div>

    <style is:global>
      :root {
        --bg-deep-space: #060913;
        --bg-card: rgba(13, 19, 39, 0.65);
        --border-glow: rgba(59, 130, 246, 0.15);
        --border-glow-hover: rgba(6, 182, 212, 0.4);
        --color-text-primary: #f3f4f6;
        --color-text-secondary: #9ca3af;
        --color-text-muted: #6b7280;
        --accent-cyan: #06b6d4;
        --accent-blue: #3b82f6;
        --accent-orange: #f97316;
        --accent-emerald: #10b981;
        --accent-purple: #8b5cf6;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background-color: var(--bg-deep-space);
        color: var(--color-text-primary);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
      }

      body::before {
        content: "";
        position: absolute;
        top: -10%;
        left: -20%;
        width: 70%;
        height: 60%;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, rgba(0, 0, 0, 0) 70%);
        z-index: -1;
        pointer-events: none;
      }

      body::after {
        content: "";
        position: absolute;
        bottom: 10%;
        right: -20%;
        width: 60%;
        height: 60%;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, rgba(0, 0, 0, 0) 70%);
        z-index: -1;
        pointer-events: none;
      }

      .glass-panel {
        background: var(--bg-card);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--border-glow);
        border-radius: 12px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
      }

      .glass-panel:hover {
        border-color: var(--border-glow-hover);
        box-shadow: 0 8px 32px 0 rgba(6, 182, 212, 0.1);
        transform: translateY(-2px);
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        letter-spacing: -0.02em;
      }

      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg-deep-space);
      }
      ::-webkit-scrollbar-thumb {
        background: #1f2937;
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #374151;
      }

      .text-glow-cyan {
        text-shadow: 0 0 10px rgba(6, 182, 212, 0.5);
      }
      .text-glow-orange {
        text-shadow: 0 0 10px rgba(249, 115, 22, 0.5);
      }

      @keyframes pulse-slow {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.9); }
      }

      .indicator-pulse {
        animation: pulse-slow 2s infinite ease-in-out;
      }

      .layout-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
    </style>
  </body>
</html>
