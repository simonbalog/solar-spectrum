---
---

<footer class="site-footer glass-panel">
  <div class="footer-grid">
    <div class="footer-info">
      <h4 class="footer-logo font-mono text-glow-cyan">MELLOTECH</h4>
      <p class="footer-desc">Empowering student aerospace engineering, rocketry systems, and avionics development.</p>
    </div>
    
    <div class="footer-partners">
      <h5 class="section-heading font-mono">SPONSORSHIP</h5>
      <p class="partners-status font-mono">LOOKING FOR PARTNERS</p>
      <p class="partners-desc">Join us in driving student aerospace innovations. Contact us to collaborate.</p>
    </div>

    <div class="footer-diagnostic">
      <h5 class="section-heading font-mono">DIAGNOSTICS</h5>
      <ul class="diag-list font-mono">
        <li>COMMS: <span class="status-ok">ONLINE</span></li>
        <li>TELEMETRY: <span class="status-ok">STANDBY</span></li>
        <li>OBC LINK: <span class="status-ok">ACTIVE</span></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="copyright font-mono">
      &copy; {new Date().getFullYear()} MELLOTECH. ALL RIGHTS RESERVED.
    </div>
    <div class="build-version font-mono">
      SYS_REV: v0.2-ALPHA
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    margin-bottom: 2rem;
    padding: 1.75rem 2rem 1.25rem 2rem;
    background: rgba(8, 12, 24, 0.7);
    border-color: rgba(59, 130, 246, 0.15);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 2fr 1fr;
    gap: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .font-mono {
    font-family: 'Space Grotesk', monospace;
  }

  .footer-logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.5rem;
    letter-spacing: 0.1em;
  }

  .footer-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .section-heading {
    font-size: 0.7rem;
    color: var(--accent-cyan);
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }

  .partners-status {
    font-size: 0.75rem;
    color: var(--accent-orange);
    font-weight: 600;
    margin-bottom: 0.25rem;
    letter-spacing: 0.02em;
  }

  .partners-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .diag-list {
    list-style: none;
    font-size: 0.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .status-ok {
    color: var(--accent-emerald);
    font-weight: bold;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    padding-top: 1rem;
    font-size: 0.65rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 480px) {
    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
