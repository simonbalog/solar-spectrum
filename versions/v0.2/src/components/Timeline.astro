---
interface TimelineEvent {
  date: string;
  title: string;
  description: string;
  status: 'done' | 'working' | 'todo';
}

const events: TimelineEvent[] = [
  {
    date: "2026-07-15",
    title: "Ground testing started",
    description: "Beginning static integration tests of flight hardware and sensors.",
    status: "working"
  },
  {
    date: "2026-07-01",
    title: "Main OBC in active development",
    description: "Designing the STM32-based Flight Computer firmware and architecture.",
    status: "working"
  },
  {
    date: "2026-06-12",
    title: "Sensor board finished",
    description: "IMU, Barometer and GPS sensor integration board designed and manufactured.",
    status: "done"
  },
  {
    date: "2026-05-20",
    title: "Power board finished",
    description: "Power distribution board (PDB) with integrated battery safety circuitry built.",
    status: "done"
  }
];
---

<div class="timeline-container glass-panel">
  <div class="timeline-header">
    <span class="timeline-tag font-mono">SYSTEM LOGS</span>
    <h3 class="timeline-title text-glow-cyan">Latest News & Updates</h3>
  </div>

  <div class="timeline-wrapper">
    {events.map((e) => (
      <div class="timeline-item">
        <div class="timeline-marker-wrapper">
          <div class={`timeline-marker ${e.status}`}>
            {e.status === 'done' && <div class="marker-dot-inner"></div>}
            {e.status === 'working' && <div class="marker-pulse-inner indicator-pulse"></div>}
          </div>
          <div class="timeline-line"></div>
        </div>
        
        <div class="timeline-content">
          <div class="timeline-meta font-mono">
            <span class="timeline-date">{e.date}</span>
            <span class={`status-badge-inline ${e.status}`}>{e.status.toUpperCase()}</span>
          </div>
          <h4 class="event-title">{e.title}</h4>
          <p class="event-desc">{e.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .timeline-container {
    padding: 1.5rem;
    background: rgba(11, 15, 25, 0.7);
    border-color: rgba(59, 130, 246, 0.2);
  }

  .timeline-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
  }

  .timeline-tag {
    font-size: 0.65rem;
    color: var(--accent-cyan);
    font-weight: 600;
  }

  .timeline-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
  }

  .timeline-wrapper {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .timeline-item {
    display: flex;
    gap: 1.25rem;
    position: relative;
  }

  .timeline-item:last-child .timeline-line {
    display: none;
  }

  .timeline-marker-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .timeline-marker {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid var(--border-glow);
    background: var(--bg-deep-space);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .timeline-marker.done {
    border-color: var(--accent-emerald);
    box-shadow: 0 0 8px rgba(16, 185, 129, 0.3);
  }

  .marker-dot-inner {
    width: 6px;
    height: 6px;
    background: var(--accent-emerald);
    border-radius: 50%;
  }

  .timeline-marker.working {
    border-color: var(--accent-orange);
    box-shadow: 0 0 8px rgba(249, 115, 22, 0.3);
  }

  .marker-pulse-inner {
    width: 6px;
    height: 6px;
    background: var(--accent-orange);
    border-radius: 50%;
  }

  .timeline-line {
    width: 2px;
    flex-grow: 1;
    background: linear-gradient(to bottom, rgba(59, 130, 246, 0.15), rgba(59, 130, 246, 0.05));
    min-height: 50px;
  }

  .timeline-content {
    padding-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .timeline-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.7rem;
  }

  .timeline-date {
    color: var(--color-text-muted);
  }

  .status-badge-inline {
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.6rem;
  }

  .status-badge-inline.done {
    background: rgba(16, 185, 129, 0.1);
    color: var(--accent-emerald);
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .status-badge-inline.working {
    background: rgba(249, 115, 22, 0.1);
    color: var(--accent-orange);
    border: 1px solid rgba(249, 115, 22, 0.2);
  }

  .event-title {
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
  }

  .event-desc {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }
</style>
