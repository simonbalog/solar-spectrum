---
interface Goal {
  id: string;
  title: string;
  description: string;
  tag: string;
}

const goals: Goal[] = [
  {
    id: "01",
    title: "Cassiopeia I — First Flight",
    description: "Validate our custom avionics stack in flight — autonomous guidance, multi-engine propulsion, and live telemetry from an in-house flight computer.",
    tag: "MISSION"
  },
  {
    id: "02",
    title: "Custom In-House Avionics Stack",
    description: "Develop and fly a fully custom flight computer — no off-the-shelf solutions.",
    tag: "HARDWARE"
  },
  {
    id: "03",
    title: "Active Apogee Control",
    description: "Implement servo-driven airbrakes for active drag modulation and apogee targeting.",
    tag: "GUIDANCE"
  },
  {
    id: "04",
    title: "Win Czech Rocket Challenge with Cassiopeia II",
    description: "Design and fly Cassiopeia II powered by our fully custom in-house OBC and compete for the top spot at the Czech Rocket Challenge.",
    tag: "COMPETITION"
  },
  {
    id: "05",
    title: "Reach EuRoC with Cassiopeia III",
    description: "Qualify and compete at the European Rocketry Challenge (EuRoC) with Cassiopeia III — the culmination of everything we've learned.",
    tag: "EUROC"
  }
];
---

<div class="goals-container glass-panel">
  <div class="goals-header">
    <span class="goals-tag font-mono">MISSION OBJECTIVES</span>
    <h3 class="goals-title text-glow-cyan">Goals</h3>
  </div>

  <ul class="goals-list">
    {goals.map((g) => (
      <li class="goal-item">
        <div class="goal-index font-mono">{g.id}</div>
        <div class="goal-content">
          <div class="goal-top">
            <span class="goal-title">{g.title}</span>
            <span class={`goal-badge font-mono tag-${g.tag.toLowerCase()}`}>{g.tag}</span>
          </div>
          <p class="goal-desc">{g.description}</p>
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
  .goals-container {
    padding: 1.5rem;
    margin-bottom: 2rem;
    background: rgba(11, 15, 25, 0.7);
    border-color: rgba(59, 130, 246, 0.2);
  }

  .goals-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .goals-tag {
    font-size: 0.65rem;
    color: var(--accent-cyan);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .goals-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
  }

  .goals-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .goal-item {
    display: flex;
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: background 0.2s ease;
    border-radius: 6px;
    padding-left: 0.5rem;
  }

  .goal-item:last-child {
    border-bottom: none;
  }

  .goal-item:hover {
    background: rgba(6, 182, 212, 0.04);
  }

  .goal-index {
    font-size: 0.7rem;
    color: var(--accent-cyan);
    font-weight: 600;
    opacity: 0.5;
    min-width: 20px;
    padding-top: 0.2rem;
  }

  .goal-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .goal-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .goal-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #ffffff;
  }

  .goal-badge {
    font-size: 0.6rem;
    font-weight: 700;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* Tag color variants */
  .tag-mission      { background: rgba(59, 130, 246, 0.12); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.25); }
  .tag-hardware     { background: rgba(139, 92, 246, 0.12); color: #a78bfa; border: 1px solid rgba(139, 92, 246, 0.25); }
  .tag-guidance     { background: rgba(6, 182, 212, 0.12);  color: var(--accent-cyan); border: 1px solid rgba(6, 182, 212, 0.25); }
  .tag-competition  { background: rgba(249, 115, 22, 0.12); color: var(--accent-orange); border: 1px solid rgba(249, 115, 22, 0.25); }
  .tag-euroc        { background: rgba(16, 185, 129, 0.12); color: var(--accent-emerald); border: 1px solid rgba(16, 185, 129, 0.25); }

  .goal-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }
</style>
