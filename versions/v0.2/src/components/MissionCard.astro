---
interface Milestone {
  name: string;
  status: 'done' | 'working' | 'todo';
}

interface Props {
  name: string;
  status: string;
  progress: number;
  targetApogee: string;
  launchSite: string;
  milestones: Milestone[];
}

const { 
  name, 
  status, 
  progress, 
  targetApogee, 
  launchSite, 
  milestones 
} = Astro.props;
---

<div class="mission-card glass-panel">
  <div class="card-header">
    <div class="mission-info">
      <span class="mission-tag font-mono">MISSION PROFILE</span>
      <h3 class="mission-name text-glow-cyan">🚀 {name}</h3>
    </div>
    <div class="status-indicator">
      <span class={`status-dot ${status.toLowerCase().replace(' ', '-')}`}></span>
      <span class="status-label font-mono">{status}</span>
    </div>
  </div>

  <div class="specs-grid font-mono">
    <div class="spec-item">
      <span class="spec-label">TARGET APOGEE:</span>
      <span class="spec-value">{targetApogee}</span>
    </div>
    <div class="spec-item">
      <span class="spec-label">LAUNCH SITE:</span>
      <span class="spec-value">{launchSite}</span>
    </div>
  </div>

  <div class="progress-section">
    <div class="progress-info font-mono">
      <span>DEVELOPMENT PROGRESS</span>
      <span class="progress-percentage">{progress}%</span>
    </div>
    <div class="progress-bar-container">
      <div class="progress-bar-fill" style={`width: ${progress}%`}>
        <div class="progress-bar-glow"></div>
      </div>
    </div>
  </div>

  <div class="milestones-section">
    <h4 class="section-title font-mono">SUB-SYSTEM MILESTONES</h4>
    <ul class="milestone-list">
      {milestones.map((m) => (
        <li class="milestone-item">
          <span class={`milestone-status ${m.status}`}>
            {m.status === 'done' && '✔'}
            {m.status === 'working' && '🔄'}
            {m.status === 'todo' && '▫'}
          </span>
          <span class={`milestone-name ${m.status}`}>{m.name}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .mission-card {
    padding: 1.5rem;
    background: rgba(11, 15, 25, 0.7);
    border-color: rgba(59, 130, 246, 0.2);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .mission-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mission-tag {
    font-size: 0.65rem;
    color: var(--accent-cyan);
    font-weight: 600;
  }

  .mission-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
  }

  .status-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-text-muted);
  }

  .status-dot.active-development {
    background-color: var(--accent-cyan);
    box-shadow: 0 0 8px var(--accent-cyan);
  }

  .status-label {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .specs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    background: rgba(0, 0, 0, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 6px;
    padding: 0.75rem;
  }

  .spec-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .spec-label {
    font-size: 0.6rem;
    color: var(--color-text-muted);
  }

  .spec-value {
    font-size: 0.85rem;
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .progress-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .progress-info {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .progress-percentage {
    color: var(--accent-emerald);
    font-weight: 700;
  }

  .progress-bar-container {
    height: 8px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.03);
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(to right, var(--accent-blue), var(--accent-emerald));
    border-radius: 4px;
    position: relative;
    transition: width 1s ease-out;
  }

  .progress-bar-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.15) 50%,
      rgba(255, 255, 255, 0) 100%)
    );
    animation: progress-shimmer 2s infinite linear;
  }

  @keyframes progress-shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  .milestones-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 1rem;
  }

  .section-title {
    font-size: 0.75rem;
    color: var(--accent-cyan);
    font-weight: 600;
  }

  .milestone-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .milestone-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
  }

  .milestone-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: bold;
  }

  .milestone-status.done {
    background: rgba(16, 185, 129, 0.1);
    color: var(--accent-emerald);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .milestone-status.working {
    background: rgba(245, 158, 11, 0.1);
    color: var(--accent-orange);
    border: 1px solid rgba(245, 158, 11, 0.3);
    animation: spin 3s infinite linear;
  }

  .milestone-status.todo {
    background: rgba(255, 255, 255, 0.02);
    color: var(--color-text-muted);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .milestone-name.done {
    color: var(--color-text-secondary);
    text-decoration: line-through;
    opacity: 0.7;
  }

  .milestone-name.working {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .milestone-name.todo {
    color: var(--color-text-muted);
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
