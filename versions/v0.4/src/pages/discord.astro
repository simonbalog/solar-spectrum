---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Discord | Mellotech">
  <main class="join-page">
    <div class="join-card glass-panel">
      <div class="join-glow-bar"></div>

      <div class="join-header">
        <span class="join-tag font-mono">DISCORD</span>
        <h1 class="join-title">Join Our Community</h1>
        <p class="join-lead">
          Talk to us directly on Discord.
        </p>
      </div>

      <div class="join-discord">
        <span class="discord-label font-mono">DISCORD</span>
        <a href="https://discord.gg/NTPgKwrTaH" target="_blank" rel="noopener noreferrer" class="discord-button">
          <span class="discord-button-text">JOIN DISCORD</span>
        </a>
        <div class="discord-code">NTPgKwrTaH</div>
        <p class="discord-hint font-mono">Click the button or copy the code above</p>
      </div>

      <div class="join-contact-info">
        <span class="contacts-label font-mono">CONTACT</span>

        <div class="contact-item">
          <span class="contact-role font-mono">MAIN LEADER</span>
          <span class="contact-name">Bedřich Březina</span>
          <a href="mailto:bedrich.brezina09@gmail.com" class="contact-email">bedrich.brezina09@gmail.com</a>
        </div>

        <div class="contact-item">
          <span class="contact-role font-mono">SOFTWARE</span>
          <span class="contact-name">Šimon Balog</span>
          <a href="mailto:simonbalog11@seznam.cz" class="contact-email">simonbalog11@seznam.cz</a>
        </div>
      </div>

      <div class="join-footer font-mono">
        See you there!
      </div>
    </div>
  </main>
</Layout>

<style>
  .join-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 4rem);
    padding: 2rem 0;
  }

  .join-card {
    max-width: 520px;
    width: 100%;
    padding: 2.5rem;
    background: rgba(8, 12, 24, 0.85);
    border-color: rgba(6, 182, 212, 0.2);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .join-card:hover {
    border-color: rgba(6, 182, 212, 0.4);
    box-shadow: 0 8px 32px rgba(6, 182, 212, 0.1);
  }

  .join-glow-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, #06b6d4, #8b5cf6, transparent);
  }

  .join-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .join-tag {
    font-size: 0.65rem;
    color: var(--accent-cyan);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .join-title {
    font-size: 2rem;
    font-weight: 700;
    color: #ffffff;
    text-shadow: 0 0 10px rgba(6, 182, 212, 0.5);
  }

  .join-lead {
    font-size: 1.1rem;
    color: var(--color-text-primary);
    margin-top: 0.5rem;
  }

  .join-discord {
    background: rgba(88, 101, 242, 0.08);
    border: 1px solid rgba(88, 101, 242, 0.25);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .discord-label {
    font-size: 0.65rem;
    color: #8b9cf7;
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .discord-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.5rem;
    background: #5865f2;
    border: none;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .discord-button:hover {
    background: #4752c4;
    box-shadow: 0 0 20px rgba(88, 101, 242, 0.3);
    transform: translateY(-1px);
  }

  .discord-button-text {
    font-family: 'Space Grotesk', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.08em;
  }

  .discord-code {
    font-family: 'Space Grotesk', monospace;
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.15em;
    user-select: all;
  }

  .discord-hint {
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .join-contact-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contacts-label {
    font-size: 0.65rem;
    color: var(--accent-cyan);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.85rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 6px;
  }

  .contact-item:hover {
    border-color: rgba(6, 182, 212, 0.2);
  }

  .contact-role {
    font-size: 0.6rem;
    color: var(--accent-cyan);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .contact-name {
    font-size: 0.95rem;
    color: #ffffff;
    font-weight: 600;
  }

  .contact-email {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .contact-email:hover {
    color: var(--accent-cyan);
  }

  .join-footer {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-align: center;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .font-mono {
    font-family: 'Space Grotesk', monospace;
  }
</style>
