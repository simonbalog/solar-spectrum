---
---

<header class="site-header glass-panel">
  <div class="header-main">
    <div class="logo-area">
      <div class="status-badge">
        <span class="indicator indicator-pulse"></span>
        <span class="status-text font-mono">SYS_STATUS: ACTIVE</span>
      </div>
      <h1 class="logo-title text-glow-cyan">MELLOTECH</h1>
      <p class="subtitle font-mono">STUDENT ROCKET DEVELOPMENT TEAM</p>
    </div>
    
    <div class="header-decoration">
      <div class="grid-cross"></div>
      <div class="coords font-mono">SYS_LOC: 49.215° N, 15.878° E</div>
    </div>
  </div>

  <div class="tagline-area">
    <div class="tagline-glow-bar"></div>
    <p class="tagline">Building reusable knowledge • Designing flight computers • Flying rockets</p>
  </div>
</header>

<style>
  .site-header {
    margin-top: 2rem;
    margin-bottom: 2rem;
    padding: 1.5rem 2rem;
    overflow: hidden;
    position: relative;
    border-color: rgba(59, 130, 246, 0.25);
  }

  /* Grid overlay decoration */
  .site-header::before {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 250px;
    height: 100%;
    background-image: 
      linear-gradient(to right, rgba(6, 182, 212, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(6, 182, 212, 0.05) 1px, transparent 1px);
    background-size: 15px 15px;
    mask-image: linear-gradient(to left, rgba(0,0,0,1) 30%, rgba(0,0,0,0) 100%);
    -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,1) 30%, rgba(0,0,0,0) 100%);
    pointer-events: none;
  }

  .header-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .font-mono {
    font-family: 'Space Grotesk', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }

  .logo-area {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.3);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    width: fit-content;
    margin-bottom: 0.5rem;
  }

  .indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--accent-emerald);
    box-shadow: 0 0 8px var(--accent-emerald);
  }

  .status-text {
    color: var(--accent-emerald);
    font-weight: 600;
  }

  .logo-title {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.15em;
    color: #ffffff;
    margin: 0;
  }

  .subtitle {
    color: var(--accent-cyan);
    font-weight: 500;
    margin-top: 0.25rem;
  }

  .header-decoration {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .coords {
    color: var(--color-text-muted);
  }

  .grid-cross {
    width: 20px;
    height: 20px;
    position: relative;
  }

  .grid-cross::before, .grid-cross::after {
    content: "";
    position: absolute;
    background: var(--accent-cyan);
    opacity: 0.4;
  }
  .grid-cross::before {
    top: 9px;
    left: 0;
    width: 20px;
    height: 2px;
  }
  .grid-cross::after {
    left: 9px;
    top: 0;
    width: 2px;
    height: 20px;
  }

  .tagline-area {
    position: relative;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .tagline-glow-bar {
    position: absolute;
    top: -1px;
    left: 0;
    width: 60px;
    height: 2px;
    background: linear-gradient(to right, var(--accent-cyan), transparent);
  }

  .tagline {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .logo-title {
      font-size: 2.2rem;
      letter-spacing: 0.1em;
    }
    
    .header-main {
      flex-direction: column;
      align-items: flex-start;
    }

    .header-decoration {
      align-items: flex-start;
      display: none;
    }
  }
</style>
